# Binary Search Program
arr = list(map(int, input("Enter sorted array elements: ").split()))
key = int(input("Enter key element: "))

low = 0
high = len(arr) - 1
comparisons = 0
found = False

while low <= high:
    mid = (low + high) // 2
    comparisons += 1

    if arr[mid] == key:
        found = True
        break

    elif key < arr[mid]:
        high = mid - 1

    else:
        low = mid + 1

if found:
    print("Key Found")
else:
    print("Key Not Found")

print("Total Comparisons =", comparisons)