# Check Duplicate Elements using Sorting

T = int(input("Enter number of test cases: "))

for t in range(T):

    n = int(input("Enter size of array: "))

    arr = list(map(int, input("Enter array elements: ").split()))

    arr.sort()

    duplicate = False

    for i in range(n - 1):

        if arr[i] == arr[i + 1]:
            duplicate = True
            break

    if duplicate:
        print("YES")
    else:
        print("NO")