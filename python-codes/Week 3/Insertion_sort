# Insertion Sort with Comparisons and Shifts Count

arr = list(map(int, input("Enter array elements: ").split()))

comparisons = 0
shifts = 0

n = len(arr)

for i in range(1, n):

    key = arr[i]
    j = i - 1

    while j >= 0:
        comparisons += 1

        if arr[j] > key:
            arr[j + 1] = arr[j]
            shifts += 1
            j -= 1
        else:
            break

    arr[j + 1] = key

print("Sorted Array:", arr)
print("Total Comparisons =", comparisons)
print("Total Shifts =", shifts)